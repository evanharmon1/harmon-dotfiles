# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Editor / IDE files
.idea/
*.swp
*~
# VS Code: commit the curated shared project config, ignore everything else
# (extensions auto-write machine-specific files into .vscode/). The broad ignore
# MUST come before the `!` whitelist — later rules win in .gitignore.
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/tasks.json
!.vscode/launch.json

# Homebrew lockfile (generated by `brew bundle`)
Brewfile.lock.json

# Node dependencies — kept in every profile (a local node_modules can appear from
# ad-hoc npm or a v2->v3 migration even in non-node repos). Build output and the
# pnpm store stay node-profile-only, in the use_node block below.
node_modules/

# logs and databases
*.log
*.sql
*.sqlite
*.sqlite3

# Taskfile fingerprint cache
.task/

# Git worktrees
.worktrees/

# Design-handoff bundles (Claude Design exports) live as specs/ subdirectories
# while being implemented and are deleted at sign-off — never committed.
# Top-level specs/*.md (README, _template, feature specs) stay tracked.
specs/*/

# Lefthook local overrides (not committed)
.lefthook-local.yml

# Local editor/AI settings
settings.local.json

# Scratch — anchored to root. (`.meta/` and the `*.code-workspace` are tracked;
# `.DS_Store` above still keeps macOS cruft out of `.meta/`.)
/todo.md

#             .env
#------------------------------------------------------------------------------
# Ignore all .env files everywhere (secrets live in 1Password; see docs/CHECKLIST.md)
.env
**/.env
.env.*
**/.env.*
.env/
