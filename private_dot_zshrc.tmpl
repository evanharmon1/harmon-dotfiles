#============================================================================
#                       Zsh Terminal Customization
#============================================================================
# Agent Deck
alias ad='agent-deck'
adf() { agent-deck worktree finish --no-merge "$@"; }
adl() { agent-deck launch . -c claude -w "feat/$1" -b -m "${*:2}"; }
# Usage: adl my-branch Implement the abc plan
# Expands to: agent-deck launch . -c claude -w feat/my-branch -b -m "Implement the abc plan"

_ghd_pick_issue() {
  gh issue list --limit "${1:-200}" \
    --json number,title \
    --template '{{ `{{range .}}{{printf "#%v\t%s\n" .number .title}}{{end}}` }}' \
    | fzf --preview 'gh issue view {1}' --preview-window=right:60% \
    | awk '{print substr($1,2)}'
}

# List GitHub Issues to pick one to send to Agent Deck to immediately implement in a new session
ghdi() {
  local issue
  issue=$(_ghd_pick_issue "$1")
  [ -z "$issue" ] && return 1

  agent-deck launch . \
    -t "issue-$issue" \
    -c "claude --dangerously-skip-permissions" \
    -w "agent/issue-$issue" \
    -b \
    -m "Implement GitHub issue #$issue. Run 'gh issue view $issue' to read the full spec, including comments and attachments, then plan, write tests, implement, and open a PR with 'Closes #$issue'."
}

# List GitHub Issues to pick one to send to Agent Deck to create a plan in a new session
ghdp() {
  local issue
  issue=$(_ghd_pick_issue "$1")
  [ -z "$issue" ] && return 1

  agent-deck launch . \
    -t "issue-$issue" \
    -c "claude --permission-mode plan" \
    -w "agent/issue-$issue" \
    -b \
    -m "Produce an implementation plan for GitHub issue #$issue. Run 'gh issue view $issue' to read the full spec, including comments and attachments. Explore the codebase as needed, then present a detailed plan via ExitPlanMode for approval. Do not implement anything yet."
}
# Usage: ghdi          # pick an issue, launch claude in agent-deck to implement it (YOLO, worktree)
#        ghdp          # pick an issue, launch claude in agent-deck plan mode (read-only, worktree)
#        ghdi 500      # raise the list limit (default 200)

# Television-based variants — uses the gh-issues channel at ~/.config/television/cable/gh-issues.toml
_gd_pick_issue() {
  if [ -n "$1" ]; then
    tv gh-issues --source-command "gh issue list --limit $1 --json number,title --template '{{ `{{range .}}{{printf \"%v\\t%s\\n\" .number .title}}{{end}}` }}'" | cut -f1
  else
    tv gh-issues | cut -f1
  fi
}

gdi() {
  local issue
  issue=$(_gd_pick_issue "$1")
  [ -z "$issue" ] && return 1

  agent-deck launch . \
    -t "issue-$issue" \
    -c "claude --dangerously-skip-permissions" \
    -w "agent/issue-$issue" \
    -b \
    -m "Implement GitHub issue #$issue. Run 'gh issue view $issue' to read the full spec, including comments and attachments, then plan, write tests, implement, and open a PR with 'Closes #$issue'."
}

gdp() {
  local issue
  issue=$(_gd_pick_issue "$1")
  [ -z "$issue" ] && return 1

  agent-deck launch . \
    -t "issue-$issue" \
    -c "claude --permission-mode plan" \
    -w "agent/issue-$issue" \
    -b \
    -m "Produce an implementation plan for GitHub issue #$issue. Run 'gh issue view $issue' to read the full spec, including comments and attachments. Explore the codebase as needed, then present a detailed plan via ExitPlanMode for approval. Do not implement anything yet."
}
# Usage: gdi           # like ghdi, but uses television (tv) instead of fzf
#        gdp           # like ghdp, but uses television (tv) instead of fzf
#        gdi 500       # override the channel's default limit (100)

