{
  // Rules live in .markdownlint.json; markdownlint-cli2 auto-merges both files.
  // This file only adds cli2-specific options.
  //
  // CHANGELOG.md is generated by release-please (which writes double blank lines
  // between sections, tripping MD012). It is not hand-edited, so never lint or
  // auto-fix it — doing so creates spurious churn on every `task verify`.
  //
  // .claude/** holds agent assets — often vendored skills whose markdown follows
  // upstream conventions. Linting/--fix-ing them mangles content (e.g. MD004
  // rewrites a leading "+ " in prose to "- "), so exclude it everywhere. Without
  // this, the lefthook markdown hook (which passes staged files explicitly) would
  // still touch them even though `task lint:markdown` skips .claude via its glob.
  "ignores": ["CHANGELOG.md", ".claude/**"]
}
