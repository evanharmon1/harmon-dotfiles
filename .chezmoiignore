# Repo-related files (not dotfiles to deploy). This repo is BOTH a chezmoi source
# AND a harmon-init-templated repo, so its repo-maintenance files live at the root
# next to the dotfiles — chezmoi must not deploy any of them to $HOME.
# Note: files starting with . are already ignored by chezmoi, so only non-dot
# files need listing here.

# Docs & meta
AGENTS.md
GEMINI.md
DESIGN.md
CHANGELOG.md
CLAUDE.md
CODE_OF_CONDUCT.md
CONTRIBUTING.md
LICENSE
README.md
todo.md
docs/**
specs/**
tests/**
harmon-dotfiles.code-workspace

# Repo tooling (task runner, git hooks, lint/commit, releases, deps, scripts)
Taskfile.yml
Brewfile
commitlint.config.mjs
lefthook.yml
release-please-config.json
renovate.json
scripts/**

# Legacy (pre-v3)
requirements.txt
check_for_pattern.sh
test/**

# SSH: kept local only. This is a PUBLIC repo, so SSH config/keys (hostnames,
# internal IPs, IdentityFile paths) must never be committed here. ~/.ssh stays
# unmanaged on each machine.
.ssh
.ssh/**

{{- if ne .chezmoi.os "darwin" }}
# macOS-only: Library paths (app configs stored in macOS-specific locations)
Library/**
# macOS-only: Mackup (iCloud-based backup)
.mackup.cfg
.mackup/**
# MacOS-only: Karabiner-Elements (keyboard remapping)
.config/karabiner
.config/karabiner/karabiner.json
{{- end }}

{{- if ne .chezmoi.os "linux" }}
# Linux-only: XDG paths for apps that use ~/Library/ on macOS
.config/ghostty/**
.config/aichat/**
.config/io.datasette.llm/**
{{- end }}
